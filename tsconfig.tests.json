{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": "."
  },
  "include": [
    "src/lib/api-errors.ts",
    "src/lib/digests.ts",
    "src/app/api/auth/request-otp/route.ts",
    "src/app/api/auth/verify-otp/route.ts",
    "src/app/api/digests/route.ts",
    "src/app/api/digests/[id]/route.ts",
    "tests/**/*.ts"
  ]
}
