# Procurement Radar SA - Environment Variables Template
# Copy this file to .env.local and fill in with actual values
# NEVER commit .env or .env.local files with real keys

# ==========================================
# Supabase Configuration
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - KEEP SECRET, only for server-side operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==========================================
# Email Configuration (Resend)
# ==========================================
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=Procurement Radar <noreply@yourdomain.com>

# ==========================================
# Application Configuration
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Crawler Configuration (Python)
CRAWLER_SCHEDULE=0 5 * * *  # 05:00 UTC daily

# ==========================================
# Security Configuration
# ==========================================
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100

# CSRF Token Secret
CSRF_SECRET=your-secret-here
OTP_HASH_SECRET=your-otp-secret-here

# ==========================================
# Optional: Monitoring & Analytics
# ==========================================
# SENTRY_DSN=https://your-sentry-dsn
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
